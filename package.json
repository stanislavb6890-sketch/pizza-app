{
  "name": "pizza-delivery-platform",
  "version": "1.0.0",
  "description": "Production-grade pizza delivery ecommerce platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npx prisma generate --schema=db/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=db/prisma/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema=db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "autoprefixer": "10.4.19",
    "bcryptjs": "2.4.3",
    "framer-motion": "^12.35.2",
    "jsonwebtoken": "9.0.2",
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "redis": "4.6.14",
    "tailwindcss": "3.4.4",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.14.0",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "@types/uuid": "10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.15",
    "jsdom": "^28.1.0",
    "prisma": "5.22.0",
    "typescript": "5.4.5",
    "vitest": "^2.1.9"
  }
}
